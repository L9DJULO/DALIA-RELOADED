# ═══════════════════════════════════════════════════════════════════════
# DALIA — Environment Variables
# ═══════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values

# ── Riot Games API ──
# Get your API key at: https://developer.riotgames.com/
# Development keys expire every 24h, production keys are permanent
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Default platform for data collection
# Options: euw1, na1, kr, eun1, br1, jp1, la1, la2, oc1, ph2, ru, sg2, th2, tr1, tw2, vn2
RIOT_PLATFORM=euw1
