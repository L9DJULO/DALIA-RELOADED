# ═══════════════════════════════════════════════════════════════════════
# DALIA — .gitignore
# Structure: server/ (FastAPI) + client/ (Tauri + React)
# ═══════════════════════════════════════════════════════════════════════

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Virtual environments ──
.venv/
venv/
ENV/

# ── Environment / Secrets ──
.env
.env.local
.env.*.local

# ── Node.js ──
node_modules/

# ── Build outputs ──
dist/
build/
*.bundle.js
client/src-tauri/target/

# ── IDE / Editor ──
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Logs ──
*.log
nohup.out
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── ML Models & Data (too large for git) ──
server/app/data/matches/
server/app/data/models/
*.pt
*.pth
*.onnx
*.pkl

# ── Cache (regenerated at runtime) ──
server/app/data/cache/
!server/app/data/cache/.gitkeep

# ── User data ──
server/app/data/users/
!server/app/data/users/.gitkeep

# ── Testing ──
coverage/
.coverage
htmlcov/

# ── Misc ──
*.bak
*.tmp
*.temp
nul

.claude
